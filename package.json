{\n  \"name\": \"portfolio-website\",\n  \"version\": \"1.0.0\",\n  \"description\": \"A modern portfolio website built with React and Node.js\",\n  \"private\": true,\n  \"workspaces\": [\n    \"frontend\",\n    \"backend\"\n  ],\n  \"scripts\": {\n    \"dev\": \"concurrently \"npm --prefix backend run dev\" \"npm --prefix frontend run dev\"\",\n    \"build\": \"npm --prefix frontend run build && npm --prefix backend run build\",\n    \"start\": \"npm --prefix backend start\"\n  },\n  \"devDependencies\": {\n    \"concurrently\": \"^7.0.0\"\n  }\n}